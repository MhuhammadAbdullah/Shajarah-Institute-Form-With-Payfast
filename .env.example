# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/shajarah_institute?schema=public"

# ── PayFast Pakistan (Hosted Checkout) ───────────────────────────────────
# Values are issued by PayFast when you sign up for a merchant account.
PAYFAST_MERCHANT_ID="your-merchant-id"
PAYFAST_MERCHANT_NAME="Shajarah Institute"
PAYFAST_SECURED_KEY="your-secured-key"
# "sandbox" while testing, "production" when you go live
PAYFAST_ENV="sandbox"

# Where PayFast redirects the customer's browser after checkout
PAYFAST_RETURN_URL="http://localhost:3000/payment/success"
PAYFAST_CANCEL_URL="http://localhost:3000/payment/failed"
# Server-to-server callback PayFast calls to confirm the transaction
PAYFAST_IPN_URL="http://localhost:3000/api/payfast/ipn"

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── SMTP (confirmation emails) ────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="apikey-or-username"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_EMAIL="registrations@shajarahinstitute.edu.pk"
SMTP_FROM_NAME="Shajarah Institute"

# ── Admin dashboard ────────────────────────────────────────────────────────
# Random string (32+ chars) used to sign admin session cookies.
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"

# Used only once by `npm run db:seed` to create the first admin account.
ADMIN_NAME="Admin"
ADMIN_EMAIL="admin@shajarahinstitute.edu.pk"
ADMIN_PASSWORD="change-me-after-first-login"
