generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentGatewayStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum FormFieldType {
  TEXT
  TEXTAREA
  EMAIL
  NUMBER
  PHONE
  DATE
  SELECT
  MULTI_SELECT
  RADIO
  CHECKBOX
  FILE
}

enum OptionSource {
  STATIC
  PROGRAMS
  CAMPUSES
  SESSIONS
}

enum RegistrationType {
  SINGLE
  MULTIPLE
}

enum DiscountType {
  PERCENT
  FIXED
}

enum PromotionDiscountType {
  PERCENT
  FIXED
  BOGO
}

model Registration {
  id       String @id @default(cuid())
  basketId String @unique

  // Student information
  studentName String
  fatherName  String?
  email       String
  phone       String
  cnic        String?
  gender      Gender
  dateOfBirth DateTime?

  // Program information
  program String
  campus  String
  session String
  fee     Decimal @db.Decimal(10, 2)

  // Address
  country    String
  province   String?
  city       String
  postalCode String?
  address    String

  agreementAccepted Boolean @default(false)

  // Promotion & discount breakdown - see services/promotionEngine.service.ts.
  // `fee` above keeps its exact original meaning (the single final amount
  // ever sent to PayFast); these are purely additive audit/display columns.
  // originalAmount = unitFee * quantity, before any discount of either layer.
  // bulkDiscountAmount = layer-1 DiscountRule tier discount (unchanged concept).
  // promotionDiscountAmount = sum of all applied Promotion discounts (layer 2).
  // fee = originalAmount - bulkDiscountAmount - promotionDiscountAmount, floored at 0.
  originalAmount          Decimal @default(0) @db.Decimal(10, 2)
  bulkDiscountAmount      Decimal @default(0) @db.Decimal(10, 2)
  promotionDiscountAmount Decimal @default(0) @db.Decimal(10, 2)
  freeRegistrationCount   Int     @default(0)
  appliedCouponCode       String?

  promotionRedemptions PromotionRedemption[]

  // Single vs multiple-participant registration (see Participant model) -
  // participantCount is denormalized for cheap list/detail display without
  // a join; the primary contact above is separate from the participants
  // being enrolled, not counted as one of them.
  registrationType RegistrationType @default(SINGLE)
  participantCount Int              @default(1)
  participants     Participant[]

  // Values for admin-created dynamic fields (Educational Info, Current
  // Studies, Professional Info, Emergency Contact, Lead Source, Additional
  // Questions) - keyed by FormField.key. Core fields above stay as named
  // columns deliberately; see prisma/schema.prisma history / plan notes.
  customFieldValues Json @default("{}")

  // Payment
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?
  transactionId String?
  accessToken   String?

  // Google Sheets sync (set after a successful IPN marks the registration
  // PAID; failures are retried from the admin panel instead of blocking
  // payment confirmation)
  sheetSyncedAt  DateTime?
  sheetSyncError String?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([paymentStatus])
  @@index([createdAt])
}

model Participant {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  order    Int
  fullName String
  email    String
  phone    String
  cnic     String
  age      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([registrationId, order])
}

model Payment {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  basketId        String
  transactionId   String?
  amount          Decimal              @db.Decimal(10, 2)
  merchantAmount  Decimal?             @db.Decimal(10, 2)
  errCode         String?
  errMessage      String?
  validationHash  String?
  paymentName     String?
  gatewayResponse Json?
  status          PaymentGatewayStatus @default(INITIATED)

  createdAt DateTime @default(now())

  @@index([basketId])
  @@index([registrationId])
}

model BasketSequence {
  id    String @id @default(cuid())
  year  Int    @unique
  value Int    @default(0)
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Single-row app-wide settings - avoids inventing a generic key-value table
// for what is currently just one value.
model SiteSetting {
  id              String   @id @default("singleton")
  maxParticipants Int      @default(10)
  updatedAt       DateTime @updatedAt
}

model Program {
  id              String             @id @default(cuid())
  name            String             @unique
  description     String?
  thumbnailUrl    String?
  isActive        Boolean            @default(true)
  displayOrder    Int                @default(0)
  feeStructures   FeeStructure[]
  campuses        ProgramCampus[]
  sessions        ProgramSession[]
  promotionScopes PromotionProgram[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([isActive, displayOrder])
}

model ProgramCampus {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  campusId  String
  campus    Campus  @relation(fields: [campusId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([programId, campusId])
}

model ProgramSession {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([programId, sessionId])
}

model Campus {
  id            String          @id @default(cuid())
  name          String          @unique
  address       String?
  isActive      Boolean         @default(true)
  displayOrder  Int             @default(0)
  feeStructures FeeStructure[]
  programs      ProgramCampus[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([isActive, displayOrder])
}

model Session {
  id              String             @id @default(cuid())
  name            String             @unique
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean            @default(true)
  displayOrder    Int                @default(0)
  feeStructures   FeeStructure[]
  programs        ProgramSession[]
  promotionScopes PromotionSession[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([isActive, displayOrder])
}

model FeeStructure {
  id String @id @default(cuid())

  programId String
  program   Program @relation(fields: [programId], references: [id])
  campusId  String
  campus    Campus  @relation(fields: [campusId], references: [id])
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  currency        String   @default("PKR")
  fee             Decimal  @db.Decimal(10, 2)
  registrationFee Decimal? @db.Decimal(10, 2)
  discountAmount  Decimal? @db.Decimal(10, 2)
  discountPercent Decimal? @db.Decimal(5, 2)
  isActive        Boolean  @default(true)

  discountRules DiscountRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, campusId, sessionId])
}

// Quantity-based bulk discount tiers for a FeeStructure - e.g. 2 registrants
// = 10% off, 3 = 15% off. The highest minQuantity <= the selected quantity
// wins; applies to the whole subtotal (unitFee * quantity) at that tier.
model DiscountRule {
  id             String       @id @default(cuid())
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  minQuantity  Int
  discountType DiscountType
  value        Decimal      @db.Decimal(10, 2)
  isActive     Boolean      @default(true)
  displayOrder Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([feeStructureId, minQuantity])
}

model FormStep {
  id           String        @id @default(cuid())
  key          String        @unique
  title        String
  description  String?
  displayOrder Int           @default(0)
  isActive     Boolean       @default(true)
  sections     FormSection[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([isActive, displayOrder])
}

model FormSection {
  id           String      @id @default(cuid())
  stepId       String
  step         FormStep    @relation(fields: [stepId], references: [id], onDelete: Cascade)
  key          String      @unique
  title        String
  description  String?
  displayOrder Int         @default(0)
  isActive     Boolean     @default(true)
  fields       FormField[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([stepId, displayOrder])
}

model FormField {
  id        String      @id @default(cuid())
  sectionId String
  section   FormSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  // Stable identifier: the customFieldValues JSON key for dynamic fields,
  // ignored (informational only) for fields with mapsToColumn set.
  key         String        @unique
  label       String
  placeholder String?
  helpText    String?
  type        FormFieldType

  isRequired   Boolean @default(false)
  isActive     Boolean @default(true)
  displayOrder Int     @default(0)
  defaultValue String?

  // { minLength?, maxLength?, min?, max?, pattern?, patternMessage?,
  //   minSelected?, maxSelected?, maxFileSizeMb?, acceptedFileTypes? }
  validationRules Json?

  // Set for SELECT/MULTI_SELECT/RADIO fields whose options are resolved
  // live from the Program/Batch/Campus/Session CMS tables instead of the
  // FormFieldOption rows below.
  optionSource OptionSource?
  options      FormFieldOption[]

  // Renders a searchable combobox instead of a plain native <select> - only
  // meaningful when type is SELECT (long option lists like Qualification).
  isSearchable Boolean @default(false)

  // Non-null for the finite set of pre-existing fields that bind to a real
  // Registration column (e.g. "studentName", "email", "program") - only
  // presentation is dynamic for these. Null means fully dynamic, stored in
  // Registration.customFieldValues[key].
  mapsToColumn String?

  // Permanent once assigned for a mapsToColumn-null field - never reused,
  // even if the field is later deactivated (see services/sheets.service.ts).
  sheetColumnIndex Int? @unique

  dependsOnFieldId String?
  dependsOnField   FormField?  @relation("FieldDependency", fields: [dependsOnFieldId], references: [id])
  dependsOnValue   String?
  dependents       FormField[] @relation("FieldDependency")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId, displayOrder])
}

model FormFieldOption {
  id      String    @id @default(cuid())
  fieldId String
  field   FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  label        String
  value        String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // If this option is selected, render one additional sibling free-text
  // field (a FormField with dependsOnValue == this option's value).
  triggersFreeText Boolean @default(false)

  @@index([fieldId, displayOrder])
}

// ── Discount & Promotion engine ─────────────────────────────────────────────
// A second, independent discount layer computed on top of the existing
// FeeStructure/DiscountRule bulk-tier system (never modified/replaced) - see
// services/promotionEngine.service.ts for the compute algorithm. Automatic
// promotions (requiresCode=false) and coupon promotions (requiresCode=true,
// unique `code`) share this one model; PERCENT/FIXED/BOGO can each be either.

model Promotion {
  id String @id @default(cuid())

  name        String // Discount Name (internal)
  description String? // Internal Description

  requiresCode Boolean @default(false)
  code         String? @unique // always stored UPPERCASED+trimmed

  publicTitle String? // Public Promotion Title
  subtitle    String? // Promotion Subtitle
  bannerText  String? // Promotion Banner Text

  discountType      PromotionDiscountType
  value             Decimal?              @db.Decimal(10, 2) // PERCENT (0-100) or FIXED amount; null for BOGO
  maxDiscountAmount Decimal?              @db.Decimal(10, 2) // cap, mainly for PERCENT

  buyQuantity  Int? // BOGO only
  freeQuantity Int? // BOGO only

  // Lifecycle - status is always computed on read (derivePromotionStatus in
  // services/promotion.service.ts), never stored, so it can never go stale.
  isActive         Boolean   @default(false)
  firstActivatedAt DateTime? // set once, first time isActive flips true - distinguishes Draft (null) from Disabled (set)
  startDate        DateTime?
  endDate          DateTime?

  priority          Int     @default(0) // higher wins
  isStackable       Boolean @default(false)
  allowBogoStacking Boolean @default(false) // this BOGO promo may combine with another already-applied BOGO

  usageLimit        Int? // total redemptions; null = unlimited
  usageLimitPerUser Int? // per user (by email); null = unlimited
  usageCount        Int  @default(0) // only ever incremented via an atomic conditional update

  minOrderAmount       Decimal? @db.Decimal(10, 2) // compared against the fixed post-layer-1 subtotal
  minRegistrationCount Int? // compared against quantity

  showOnForm Boolean @default(true) // banner eligibility
  isFeatured Boolean @default(false)

  bannerColor  String?
  bannerIcon   String?
  displayOrder Int     @default(0)

  programs    PromotionProgram[]
  sessions    PromotionSession[]
  redemptions PromotionRedemption[]
  auditLogs   PromotionAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startDate, endDate])
  @@index([requiresCode, code])
}

// Empty relation set on a Promotion = applies to ALL programs/sessions.
model PromotionProgram {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  programId   String
  program     Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([promotionId, programId])
}

model PromotionSession {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([promotionId, sessionId])
}

// One row per (promotion, registration) - the authoritative record of what
// applied and how much it contributed. Substrate for per-user usage checks
// and the admin "Revenue Saved" stat. Deliberately not a scalar FK on
// Registration, since stacking means more than one promotion can apply to a
// single registration.
model PromotionRedemption {
  id             String       @id @default(cuid())
  promotionId    String
  promotion      Promotion    @relation(fields: [promotionId], references: [id])
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  userEmail      String // denormalized from Registration.email - avoids a join for the per-user usage check
  discountAmount Decimal @db.Decimal(10, 2) // this promotion's own contribution
  freeCount      Int? // BOGO only

  createdAt DateTime @default(now())

  @@unique([promotionId, registrationId])
  @@index([promotionId, userEmail])
}

// Admin-action audit trail (create/update/enable/disable/delete/duplicate) -
// a separate concern from PromotionRedemption (customer usage).
model PromotionAuditLog {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  action     String // "CREATED" | "UPDATED" | "ENABLED" | "DISABLED" | "DELETED" | "DUPLICATED"
  adminId    String?
  adminEmail String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([promotionId, createdAt])
}
